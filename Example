-- ═══════════════════════════════════════
--   NEXUS UI LIBRARY — Пример использования
-- ═══════════════════════════════════════

local Nexus = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/YOURNAME/NexusLib/main/NexusLib.lua"
))()

-- Создаём окно
local Window = Nexus:CreateWindow({
    Title   = "My Hub",
    SubText = "v1.0",
    Key     = Enum.KeyCode.F9,   -- клавиша открыть/закрыть
    Size    = UDim2.new(0, 620, 0, 420),
})

-- ─── Таб: Движение ───────────────────
local Movement = Window:AddTab("Движение")

Movement:AddSlider({
    Name     = "WalkSpeed",
    Min      = 1,
    Max      = 200,
    Default  = 16,
    Suffix   = "",
    Callback = function(v)
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
    end
})

Movement:AddSlider({
    Name     = "JumpPower",
    Min      = 0,
    Max      = 300,
    Default  = 50,
    Callback = function(v)
        game.Players.LocalPlayer.Character.Humanoid.JumpPower = v
    end
})

Movement:AddToggle({
    Name     = "Infinite Jump",
    Default  = false,
    Callback = function(enabled)
        _G.InfJump = enabled
    end
})

Movement:AddToggle({
    Name     = "Noclip",
    Default  = false,
    Callback = function(enabled)
        _G.Noclip = enabled
    end
})

Movement:AddButton({
    Name     = "Сбросить персонажа",
    Callback = function()
        game.Players.LocalPlayer.Character:BreakJoints()
    end
})

-- ─── Таб: Визуал ─────────────────────
local Visual = Window:AddTab("Визуал")

Visual:AddSlider({
    Name     = "FOV",
    Min      = 50,
    Max      = 120,
    Default  = 70,
    Callback = function(v)
        game.Workspace.CurrentCamera.FieldOfView = v
    end
})

Visual:AddColorPicker({
    Name     = "Цвет акцента",
    Default  = Color3.fromRGB(255, 255, 255),
    Callback = function(color)
        print("Выбран цвет:", color)
    end
})

Visual:AddDropdown({
    Name     = "Тип камеры",
    Options  = {"Classic", "Follow", "Orbital", "Scriptable"},
    Default  = "Classic",
    Callback = function(value)
        game.Workspace.CurrentCamera.CameraType = Enum.CameraType[value]
    end
})

Visual:AddSeparator()
Visual:AddLabel("Настройки персонажа")

Visual:AddColorPicker({
    Name     = "Цвет туловища",
    Default  = Color3.fromRGB(17, 103, 177),
    Callback = function(color)
        local char = game.Players.LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetChildren()) do
                if part:IsA("BasePart") then
                    part.BrickColor = BrickColor.new(color)
                end
            end
        end
    end
})

-- ─── Таб: Игрок ──────────────────────
local Player = Window:AddTab("Игрок")

Player:AddTextbox({
    Name     = "Телепорт к игроку",
    Default  = "",
    Callback = function(name)
        local target = game.Players:FindFirstChild(name)
        if target and target.Character then
            game.Players.LocalPlayer.Character:SetPrimaryPartCFrame(
                target.Character.PrimaryPart.CFrame + Vector3.new(3, 0, 0)
            )
        end
    end
})

Player:AddSlider({
    Name     = "Здоровье",
    Min      = 0,
    Max      = 100,
    Default  = 100,
    Suffix   = "hp",
    Callback = function(v)
        game.Players.LocalPlayer.Character.Humanoid.Health = v
    end
})

Player:AddKeybind({
    Name     = "Спринт",
    Default  = Enum.KeyCode.LeftShift,
    Callback = function(key)
        print("Спринт назначен на:", key.Name)
    end
})

Player:AddToggle({
    Name     = "Невидимость",
    Default  = false,
    Callback = function(enabled)
        local char = game.Players.LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") or part:IsA("Decal") then
                    part.Transparency = enabled and 1 or 0
                end
            end
        end
    end
})

-- ─── Уведомление при загрузке ────────
Nexus:Notify({
    Title    = "Nexus загружен",
    Text     = "Нажми F9 чтобы открыть/закрыть",
    Duration = 4,
})

-- ─── Infinite Jump логика ────────────
game:GetService("UserInputService").JumpRequest:Connect(function()
    if _G.InfJump then
        game.Players.LocalPlayer.Character.Humanoid:ChangeState(
            Enum.HumanoidStateType.Jumping
        )
    end
end)

-- ─── Noclip логика ───────────────────
game:GetService("RunService").Stepped:Connect(function()
    if _G.Noclip then
        for _, part in pairs(game.Players.LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)
